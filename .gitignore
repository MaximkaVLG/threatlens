# ML artifacts (datasets are large, models are binaries)
# Use data/* not data/ so we can re-include specific files via !data/...
data/*
results/
models/
*.joblib
*.pkl
*.parquet

# Day 13 sandbox-ingest output — modern (2024-2026) malware PCAPs.
# Re-downloadable by `python scripts/ingest_sandbox_pcaps.py`.
# We keep the parquet (small) but never commit raw PCAPs (50-200 MB each,
# may also be flagged by users' antivirus on `git clone`).
# Re-allow descent into the sandbox dir so we can whitelist the frozen
# metadata snapshot (Phase 0 audit trail — defines which 27 PCAPs the v2
# stratified split was built from). Tiny (~30 KB).
!data/sandbox_malware/
data/sandbox_malware/*
!data/sandbox_malware/metadata.frozen.jsonl

# ...except production model snapshot required for Railway / timeweb deploy
!results/
!results/cicids2017/
!results/cicids2017/*.joblib
!results/cicids2017/metrics.json
!results/cicids2017/comparison.csv

# Day 5 combined-retrain candidate (Day 11 will decide whether to flip prod)
# RandomForest stays ignored — its joblib is ~816 MB and the project's
# primary model is XGBoost anyway.
!results/combined_v2/
!results/combined_v2/xgboost.joblib
!results/combined_v2/feature_pipeline.joblib
!results/combined_v2/metrics.json
!results/combined_v2/comparison.csv
!results/combined_v2/head_to_head.json
!results/combined_v2/mahalanobis_abstainer.joblib

# Day 9 python-only retrain — closes the Java-vs-Python extractor drift gap.
# These artifacts are the candidate for the production swap on Day 11.
!results/python_only/
!results/python_only/xgboost.joblib
!results/python_only/feature_pipeline.joblib
!results/python_only/mahalanobis_abstainer.joblib
!results/python_only/mahalanobis_abstainer_summary.json
!results/python_only/metrics.json
!results/python_only/real_world_eval.json
!results/python_only/ctu_test_holdout.parquet
!results/python_only/diverse_benign_flows.parquet
!results/python_only/attack_volume_flows.parquet
# Day 11 + Day 12 + Day 13 evaluation artefacts (small, reproducibility-critical)
!results/python_only/workload_metric.json
!results/python_only/active_learning_demo.json
!results/python_only/sandbox_eval.json
!results/python_only/sandbox_malware_flows.parquet
# Phase 1 split artefacts (sandbox stratified into 16 train + 9 holdout PCAPs)
!results/python_only/sandbox_split.json
!results/python_only/sandbox_train_flows.parquet
!results/python_only/sandbox_holdout_flows.parquet
# Phase 5 bootstrap CI (head-to-head, both bundles)
!results/python_only/bootstrap_ci.json
!results/python_only/bootstrap_ci.md

# Phase 1 v2 retrain candidate (sandbox-train + sample-weight 0.5)
# Ships as the production swap on Phase 1.6 if A/B head-to-head says go.
!results/v2/
!results/v2/xgboost.joblib
!results/v2/feature_pipeline.joblib
!results/v2/mahalanobis_abstainer.joblib
!results/v2/mahalanobis_abstainer_summary.json
!results/v2/metrics.json
!results/v2/real_world_eval.json
!results/v2/sandbox_eval.json
!results/v2/sandbox_holdout_eval.json
!results/v2/sandbox_holdout_eval_with_abstainer.json
!results/v2/workload_metric.json
!results/v2/ctu_test_holdout.parquet
!results/v2/ab_vs_python_only.md
!results/v2/bootstrap_ci.json
!results/v2/bootstrap_ci.md

# Day 6-8 evaluation JSON artefacts (small, worth committing for reproducibility)
!results/real_world_eval_ab.json
!results/feature_drift_diag.json
!results/selective_eval.json
!results/selective_sweep.json

# Real-world flow extraction cache (parquet) — large enough to regenerate,
# but keep small version committed to skip 16 min re-extract during CI
# (Actually, stay ignored — it's 1282 rows times 89 cols of float, small,
# but not source-of-truth. Regenerate on demand.)
results/real_world_flows_cache.parquet

# Local experiment outputs (synthetic training set, ad-hoc runs)
results/synthetic/
results/experiments/
results/*_training.log

# Phase 3 adversarial work — per-cell perturbed PCAPs (50-100MB each).
# Deleted after each cell completes; pattern keeps any leftover from a
# crashed run out of git.
results/*/.adversarial_work/
